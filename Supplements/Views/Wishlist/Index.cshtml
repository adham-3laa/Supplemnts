@model Supplements.ViewModels.Wishlist.WishlistViewModel
@{
    ViewData["Title"] = "My Wishlist";
}
<div class="max-w-6xl mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2">My Wishlist</h1>
        @if (!Model.IsEmpty)
        {
            <p class="text-gray-600 dark:text-gray-400">
                <span class="font-medium text-gray-900 dark:text-white">@Model.Items.Count</span> items saved
            </p>
        }
    </div>

    @if (Model.IsEmpty)
    {
        <partial name="_EmptyState" view-data='new ViewDataDictionary(ViewData) { { "EmptyIcon", "favorite_border" }, { "EmptyTitle", "Your wishlist is empty" }, { "EmptyMessage", "Save items you love to your wishlist." }, { "EmptyActionText", "Browse Products" }, { "EmptyActionUrl", "/Shop" } }' />
    }
    else
    {
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
            @foreach (var item in Model.Items)
            {
                <div class="card overflow-hidden hover:shadow-xl transition-all duration-300 animate-slide-up relative group">
                    <a href="/Shop/Details/@item.ProductId" class="block relative overflow-hidden aspect-square bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-700">
                        @if (!string.IsNullOrEmpty(item.MainImageUrl))
                        {
                            <img src="@item.MainImageUrl" alt="@item.ProductName" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                        }
                        else
                        {
                            <div class="flex items-center justify-center h-full">
                                <span class="material-icons text-6xl text-gray-300 dark:text-gray-600">inventory_2</span>
                            </div>
                        }

                        <div class="absolute top-3 right-3">
                            <span class="inline-flex items-center justify-center w-10 h-10 bg-red-500 text-white rounded-full shadow-lg">
                                <span class="material-icons text-lg">favorite</span>
                            </span>
                        </div>
                    </a>

                    <div class="p-4">
                        <a href="/Shop/Details/@item.ProductId" class="block font-bold text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400 transition-base line-clamp-2 mb-3">
                            @item.ProductName
                        </a>

                        <div class="flex items-center justify-between gap-2">
                            <span class="text-xl font-bold text-primary-600 dark:text-primary-400">$@item.FinalPrice.ToString("F2")</span>
                            <form method="post" action="/Wishlist/RemoveFromWishlist/@item.Id">
                                <button type="submit" class="p-2 text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-base" title="Remove from wishlist">
                                    <span class="material-icons">delete</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-8">
            <a href="/Shop" class="btn btn-outline">
                <span class="material-icons">arrow_back</span>
                Continue Shopping
            </a>
        </div>
    }
</div>
