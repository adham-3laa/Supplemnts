@model Supplements.ViewModels.Checkout.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}
<div class="max-w-6xl mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2">Checkout</h1>
        <p class="text-gray-600 dark:text-gray-400">Complete your order</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Shipping Address -->
            <div class="card animate-slide-up">
                <div class="p-6 bg-gradient-to-br from-primary-50 to-white dark:from-primary-900/10 dark:to-gray-900 border-b border-gray-200 dark:border-gray-800">
                    <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
                        <span class="material-icons text-primary-600 dark:text-primary-400">local_shipping</span>
                        Shipping Address
                    </h2>
                </div>

                <div class="p-6">
                    @if (!Model.Addresses.Any())
                    {
                        <div class="text-center py-8">
                            <div class="w-16 h-16 bg-gray-100 dark:bg-gray-800 rounded-2xl flex items-center justify-center mx-auto mb-4">
                                <span class="material-icons text-3xl text-gray-400">location_off</span>
                            </div>
                            <p class="text-gray-600 dark:text-gray-400 mb-4">No shipping addresses found.</p>
                            <a href="/Profile/AddAddress" class="btn btn-primary">
                                <span class="material-icons">add</span>
                                Add Address
                            </a>
                        </div>
                    }
                    else
                    {
                        <form method="post" action="/Checkout/PlaceOrder" id="checkoutForm">
                            <input type="hidden" name="selectedAddressId" id="selectedAddressId" value="@Model.SelectedAddressId" />
                            <input type="hidden" name="notes" id="checkoutNotes" value="" />

                            <div class="space-y-3 mb-6">
                                @foreach (var addr in Model.Addresses)
                                {
                                    <label class="flex items-start gap-4 p-5 rounded-xl border-2 cursor-pointer transition-all duration-200 @(Model.SelectedAddressId == addr.Id ? "border-primary-500 bg-primary-50 dark:bg-primary-900/20 shadow-md" : "border-gray-200 dark:border-gray-700 hover:border-primary-300 dark:hover:border-primary-700")">
                                        <input type="radio"
                                               name="selectedAddress"
                                               value="@addr.Id"
                                               @(Model.SelectedAddressId == addr.Id ? "checked" : "")
                                               onchange="document.getElementById('selectedAddressId').value=this.value"
                                               class="mt-1 w-5 h-5 text-primary-600 focus:ring-primary-500 focus:ring-2" />
                                        <div class="flex-1">
                                            <div class="flex items-start justify-between gap-2 mb-2">
                                                <p class="font-bold text-gray-900 dark:text-white">@addr.FullAddress</p>
                                                @if (addr.IsDefault)
                                                {
                                                    <span class="badge badge-primary">Default</span>
                                                }
                                            </div>
                                            <p class="text-sm text-gray-600 dark:text-gray-400">@addr.City, @addr.Country</p>
                                        </div>
                                    </label>
                                }
                            </div>

                            <a href="/Profile/AddAddress" class="inline-flex items-center gap-2 text-sm text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-medium">
                                <span class="material-icons text-lg">add</span>
                                Add New Address
                            </a>
                        </form>
                    }
                </div>
            </div>

            <!-- Order Notes -->
            @if (Model.Addresses.Any())
            {
                <div class="card animate-slide-up">
                    <div class="p-6 bg-gradient-to-br from-primary-50 to-white dark:from-primary-900/10 dark:to-gray-900 border-b border-gray-200 dark:border-gray-800">
                        <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
                            <span class="material-icons text-primary-600 dark:text-primary-400">note</span>
                            Order Notes
                        </h2>
                    </div>
                    <div class="p-6">
                        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                            Special Instructions (Optional)
                        </label>
                        <textarea id="orderNotes"
                                  rows="4"
                                  class="input resize-none"
                                  placeholder="Add any special delivery instructions or notes..."></textarea>
                    </div>
                </div>

                <!-- Order Items -->
                <div class="card animate-slide-up">
                    <div class="p-6 bg-gradient-to-br from-primary-50 to-white dark:from-primary-900/10 dark:to-gray-900 border-b border-gray-200 dark:border-gray-800">
                        <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
                            <span class="material-icons text-primary-600 dark:text-primary-400">inventory_2</span>
                            Order Items
                        </h2>
                    </div>
                    <div class="p-6 space-y-4">
                        @foreach (var item in Model.Items)
                        {
                            <div class="flex items-center justify-between py-3 border-b border-gray-100 dark:border-gray-800 last:border-0">
                                <div class="flex-1">
                                    <p class="font-semibold text-gray-900 dark:text-white">@item.ProductName</p>
                                    <p class="text-sm text-gray-500 dark:text-gray-400">
                                        Qty: @item.Quantity × $@item.UnitPrice.ToString("F2")
                                    </p>
                                </div>
                                <p class="text-lg font-bold text-gray-900 dark:text-white">$@item.TotalPrice.ToString("F2")</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Order Summary Sidebar -->
        <div class="lg:col-span-1">
            <div class="card sticky top-24 animate-slide-up">
                <div class="p-6 bg-gradient-to-br from-primary-50 to-white dark:from-primary-900/10 dark:to-gray-900 border-b border-gray-200 dark:border-gray-800">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Order Summary</h3>
                </div>

                <div class="p-6 space-y-4">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600 dark:text-gray-400">Subtotal</span>
                        <span class="font-semibold text-gray-900 dark:text-white">$@Model.SubTotal.ToString("F2")</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600 dark:text-gray-400">Shipping</span>
                        <span class="font-semibold text-gray-900 dark:text-white">$@Model.ShippingCost.ToString("F2")</span>
                    </div>

                    <div class="divider"></div>

                    <div class="flex justify-between items-center">
                        <span class="text-lg font-bold text-gray-900 dark:text-white">Total</span>
                        <span class="text-2xl font-bold text-primary-600 dark:text-primary-400">$@Model.TotalPrice.ToString("F2")</span>
                    </div>

                    <button type="submit"
                            form="checkoutForm"
                            onclick="document.getElementById('checkoutNotes').value=document.getElementById('orderNotes')?.value || ''"
                            class="btn btn-primary w-full @(Model.Addresses.Any() ? "" : "opacity-50 cursor-not-allowed")"
                            @(Model.Addresses.Any() ? "" : "disabled")>
                        <span class="material-icons">shopping_bag</span>
                        Place Order
                    </button>

                    <a href="/Cart" class="btn btn-outline w-full">
                        <span class="material-icons">arrow_back</span>
                        Back to Cart
                    </a>

                    <!-- Security Badges -->
                    <div class="pt-4 space-y-3">
                        <div class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
                            <span class="material-icons text-primary-600 dark:text-primary-400">lock</span>
                            <span>Secure SSL encryption</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
                            <span class="material-icons text-primary-600 dark:text-primary-400">verified</span>
                            <span>100% secure payment</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
                            <span class="material-icons text-primary-600 dark:text-primary-400">support_agent</span>
                            <span>24/7 customer support</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
