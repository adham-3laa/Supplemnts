@model Supplements.ViewModels.Profile.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2">Change Password</h1>
        <p class="text-gray-600 dark:text-gray-400">Update your account password</p>
    </div>

    <div class="card animate-slide-up">
        <div class="p-6 bg-gradient-to-br from-primary-50 to-white dark:from-primary-900/10 dark:to-gray-900 border-b border-gray-200 dark:border-gray-800">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
                <span class="material-icons text-primary-600 dark:text-primary-400">lock</span>
                Security Settings
            </h2>
        </div>

        <div class="p-8">
            <form method="post" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 text-sm p-4 rounded-xl @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

                <div>
                    <label asp-for="CurrentPassword" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-icons text-gray-400 text-lg">lock_open</span>
                        <input asp-for="CurrentPassword" class="input pl-12" placeholder="Enter current password" />
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div class="divider"></div>

                <div>
                    <label asp-for="NewPassword" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-icons text-gray-400 text-lg">lock</span>
                        <input asp-for="NewPassword" class="input pl-12" placeholder="Enter new password" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="ConfirmNewPassword" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-icons text-gray-400 text-lg">verified_user</span>
                        <input asp-for="ConfirmNewPassword" class="input pl-12" placeholder="Confirm new password" />
                    </div>
                    <span asp-validation-for="ConfirmNewPassword" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-4">
                    <div class="flex gap-3">
                        <span class="material-icons text-blue-600 dark:text-blue-400 text-lg">info</span>
                        <div class="text-sm text-blue-700 dark:text-blue-300">
                            <p class="font-semibold mb-1">Password Requirements:</p>
                            <ul class="list-disc list-inside space-y-1 text-blue-600 dark:text-blue-400">
                                <li>At least 8 characters long</li>
                                <li>Contains uppercase and lowercase letters</li>
                                <li>Contains at least one number</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="divider"></div>

                <div class="flex flex-wrap gap-3">
                    <button type="submit" class="btn btn-primary">
                        <span class="material-icons">save</span>
                        Update Password
                    </button>
                    <a href="/Profile" class="btn btn-outline">
                        <span class="material-icons">close</span>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
