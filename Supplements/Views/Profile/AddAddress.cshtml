@model Supplements.ViewModels.Profile.AddressFormViewModel
@{
    ViewData["Title"] = "Add Address";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2">Add Address</h1>
        <p class="text-gray-600 dark:text-gray-400">Add a new shipping address</p>
    </div>

    <div class="card animate-slide-up">
        <div class="p-6 bg-gradient-to-br from-primary-50 to-white dark:from-primary-900/10 dark:to-gray-900 border-b border-gray-200 dark:border-gray-800">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
                <span class="material-icons text-primary-600 dark:text-primary-400">add_location</span>
                Address Details
            </h2>
        </div>

        <div class="p-8">
            <form method="post" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 text-sm p-4 rounded-xl @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

                <div>
                    <label asp-for="Country" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-icons text-gray-400 text-lg">public</span>
                        <input asp-for="Country" class="input pl-12" placeholder="Enter country" />
                    </div>
                    <span asp-validation-for="Country" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="City" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-icons text-gray-400 text-lg">location_city</span>
                        <input asp-for="City" class="input pl-12" placeholder="Enter city" />
                    </div>
                    <span asp-validation-for="City" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Street" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-icons text-gray-400 text-lg">signpost</span>
                        <input asp-for="Street" class="input pl-12" placeholder="Enter street name" />
                    </div>
                    <span asp-validation-for="Street" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="BuildingNumber" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-icons text-gray-400 text-lg">apartment</span>
                            <input asp-for="BuildingNumber" class="input pl-12" placeholder="Bldg #" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="Floor" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-icons text-gray-400 text-lg">stairs</span>
                            <input asp-for="Floor" class="input pl-12" placeholder="Floor #" />
                        </div>
                    </div>
                </div>

                <div>
                    <label asp-for="Notes" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                    <textarea asp-for="Notes" rows="3" class="input resize-none" placeholder="Any additional delivery notes..."></textarea>
                </div>

                <div>
                    <label class="flex items-center gap-3 cursor-pointer p-4 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 transition-base">
                        <input asp-for="IsDefault" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 text-primary-600 focus:ring-primary-500 focus:ring-2" />
                        <div>
                            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Set as default address</span>
                            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">This address will be pre-selected during checkout</p>
                        </div>
                    </label>
                </div>

                <div class="divider"></div>

                <div class="flex flex-wrap gap-3">
                    <button type="submit" class="btn btn-primary">
                        <span class="material-icons">save</span>
                        Save Address
                    </button>
                    <a href="/Profile/Addresses" class="btn btn-outline">
                        <span class="material-icons">close</span>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
