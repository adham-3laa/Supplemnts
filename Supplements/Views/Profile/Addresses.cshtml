@model Supplements.ViewModels.Profile.AddressListViewModel
@{
    ViewData["Title"] = "My Addresses";
}
<div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2">My Addresses</h1>
            <p class="text-gray-600 dark:text-gray-400">Manage your shipping addresses</p>
        </div>
        <a href="/Profile/AddAddress" class="btn btn-primary">
            <span class="material-icons">add</span>
            Add Address
        </a>
    </div>

    @if (!Model.Addresses.Any())
    {
        <partial name="_EmptyState" view-data='new ViewDataDictionary(ViewData) { { "EmptyIcon", "location_off" }, { "EmptyTitle", "No addresses yet" }, { "EmptyMessage", "Add an address to start receiving orders." }, { "EmptyActionText", "Add Address" }, { "EmptyActionUrl", "/Profile/AddAddress" } }' />
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @foreach (var address in Model.Addresses)
            {
                <div class="card card-body animate-slide-up transition-all duration-300 hover:shadow-lg @(address.IsDefault ? "ring-2 ring-primary-500 dark:ring-primary-400" : "")">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-gradient-to-br from-primary-100 to-primary-200 dark:from-primary-900/30 dark:to-primary-800/30 rounded-xl flex items-center justify-center">
                                <span class="material-icons text-primary-600 dark:text-primary-400">location_on</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 dark:text-white">@address.FullAddress</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400">@address.Country - @address.City</p>
                            </div>
                        </div>
                        @if (address.IsDefault)
                        {
                            <span class="badge badge-primary">Default</span>
                        }
                    </div>

                    <div class="divider mb-4"></div>

                    <div class="flex items-center gap-3">
                        <a href="/Profile/EditAddress/@address.Id" class="btn btn-outline btn-sm">
                            <span class="material-icons text-sm">edit</span>
                            Edit
                        </a>
                        <form method="post" action="/Profile/DeleteAddress/@address.Id" onsubmit="return confirm('Are you sure you want to delete this address?')">
                            <button type="submit" class="btn btn-sm bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/40 border border-red-200 dark:border-red-800">
                                <span class="material-icons text-sm">delete</span>
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-6">
        <a href="/Profile" class="btn btn-outline">
            <span class="material-icons">arrow_back</span>
            Back to Profile
        </a>
    </div>
</div>
