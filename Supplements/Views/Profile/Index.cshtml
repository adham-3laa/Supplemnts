@model Supplements.ViewModels.Profile.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}
<div class="max-w-4xl mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2">My Profile</h1>
        <p class="text-gray-600 dark:text-gray-400">Manage your account information</p>
    </div>

    <div class="card animate-slide-up">
        <div class="p-8 bg-gradient-to-br from-primary-50 to-white dark:from-primary-900/10 dark:to-gray-900 border-b border-gray-200 dark:border-gray-800">
            <div class="flex items-center gap-6">
                <div class="w-24 h-24 bg-gradient-to-br from-primary-100 to-primary-200 dark:from-primary-900/30 dark:to-primary-800/30 rounded-2xl flex items-center justify-center shadow-lg">
                    <span class="material-icons text-5xl text-primary-600 dark:text-primary-400">person</span>
                </div>
                <div>
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">@Model.FullName</h2>
                    <p class="text-sm text-gray-600 dark:text-gray-400 flex items-center gap-2">
                        <span class="material-icons text-base">email</span>
                        @Model.Email
                    </p>
                </div>
            </div>
        </div>

        <div class="p-8">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="material-icons text-primary-600 dark:text-primary-400">info</span>
                Account Information
            </h3>

            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
                <div class="p-5 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700">
                    <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-2 flex items-center gap-2">
                        <span class="material-icons text-base">badge</span>
                        Full Name
                    </dt>
                    <dd class="text-base font-bold text-gray-900 dark:text-white">@Model.FullName</dd>
                </div>
                <div class="p-5 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700">
                    <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-2 flex items-center gap-2">
                        <span class="material-icons text-base">email</span>
                        Email Address
                    </dt>
                    <dd class="text-base font-bold text-gray-900 dark:text-white">@Model.Email</dd>
                </div>
                <div class="p-5 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700">
                    <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-2 flex items-center gap-2">
                        <span class="material-icons text-base">phone</span>
                        Phone Number
                    </dt>
                    <dd class="text-base font-bold text-gray-900 dark:text-white">@(Model.PhoneNumber ?? "Not set")</dd>
                </div>
                <div class="p-5 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700">
                    <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-2 flex items-center gap-2">
                        <span class="material-icons text-base">calendar_today</span>
                        Member Since
                    </dt>
                    <dd class="text-base font-bold text-gray-900 dark:text-white">@Model.CreatedAt.ToString("MMMM dd, yyyy")</dd>
                </div>
            </dl>

            <div class="divider mb-6"></div>

            <div class="flex flex-wrap gap-3">
                <a href="/Profile/Edit" class="btn btn-primary">
                    <span class="material-icons">edit</span>
                    Edit Profile
                </a>
                <a href="/Profile/ChangePassword" class="btn btn-outline">
                    <span class="material-icons">lock</span>
                    Change Password
                </a>
                <a href="/Profile/Addresses" class="btn btn-outline">
                    <span class="material-icons">location_on</span>
                    Manage Addresses
                </a>
            </div>
        </div>
    </div>
</div>
