@model Supplements.ViewModels.Account.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_AuthLayout";
}
<div class="card shadow-xl animate-scale-in">
    <div class="card-body">
        <div class="text-center mb-8">
            <div class="w-20 h-20 bg-gradient-to-br from-primary-100 to-primary-200 dark:from-primary-900/30 dark:to-primary-800/30 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg">
                <span class="material-icons text-4xl text-primary-600 dark:text-primary-400">person_add</span>
            </div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Create Account</h1>
            <p class="text-gray-600 dark:text-gray-400">Join us and start your fitness journey</p>
        </div>

        <form method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 text-sm p-4 rounded-xl @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

            <div>
                <label asp-for="FullName" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="FullName" class="input" placeholder="John Doe" autofocus />
                <span asp-validation-for="FullName" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="Email" class="input" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="PhoneNumber" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="PhoneNumber" class="input" placeholder="+1 (555) 123-4567" />
                <span asp-validation-for="PhoneNumber" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="Password" class="input" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="ConfirmPassword" class="input" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <button type="submit" class="btn btn-primary w-full">
                <span class="material-icons">person_add</span>
                Create Account
            </button>

            <div class="relative my-6">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-gray-200 dark:border-gray-700"></div>
                </div>
                <div class="relative flex justify-center text-sm">
                    <span class="px-4 bg-white dark:bg-gray-900 text-gray-500 dark:text-gray-400">Already have an account?</span>
                </div>
            </div>

            <a href="/Account/Login" class="btn btn-outline w-full">
                <span class="material-icons">login</span>
                Sign In
            </a>
        </form>
    </div>
</div>
