@model Supplements.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_AuthLayout";
}
<div class="card shadow-xl animate-scale-in">
    <div class="card-body">
        <div class="text-center mb-8">
            <div class="w-20 h-20 bg-gradient-to-br from-primary-100 to-primary-200 dark:from-primary-900/30 dark:to-primary-800/30 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg">
                <span class="material-icons text-4xl text-primary-600 dark:text-primary-400">lock</span>
            </div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Welcome Back</h1>
            <p class="text-gray-600 dark:text-gray-400">Sign in to continue your fitness journey</p>
        </div>

        <form method="post" class="space-y-5">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

            <div asp-validation-summary="ModelOnly" class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 text-sm p-4 rounded-xl @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

            <div>
                <label asp-for="Email" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="Email" class="input" placeholder="you@example.com" autofocus />
                <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="Password" class="input" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div class="flex items-center justify-between">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input asp-for="RememberMe" class="w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-primary-600 focus:ring-primary-500 focus:ring-2" />
                    <span class="text-sm text-gray-600 dark:text-gray-400">Remember me</span>
                </label>
                <a href="#" class="text-sm text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-medium">
                    Forgot password?
                </a>
            </div>

            <button type="submit" class="btn btn-primary w-full">
                <span class="material-icons">login</span>
                Sign In
            </button>

            <div class="relative my-6">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-gray-200 dark:border-gray-700"></div>
                </div>
                <div class="relative flex justify-center text-sm">
                    <span class="px-4 bg-white dark:bg-gray-900 text-gray-500 dark:text-gray-400">New to SupplementsStore?</span>
                </div>
            </div>

            <a href="/Account/Register" class="btn btn-outline w-full">
                <span class="material-icons">person_add</span>
                Create Account
            </a>
        </form>
    </div>
</div>
