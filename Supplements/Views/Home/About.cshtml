@{
    ViewData["Title"] = "About Us";
}
<div class="max-w-5xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12 animate-slide-up">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4">About SupplementsStore</h1>
        <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
            Your premier destination for high-quality nutritional supplements and wellness products.
        </p>
    </div>

    <!-- Story Section -->
    <div class="card card-body mb-8 animate-slide-up">
        <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
            Welcome to SupplementsStore, where we're dedicated to providing fitness enthusiasts and health-conscious individuals with the best products to support their wellness journey. We believe that everyone deserves access to premium supplements that help them achieve their goals.
        </p>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Founded by fitness professionals and nutrition experts, we understand what it takes to reach peak performance. That's why we carefully curate our selection to include only the highest quality products from trusted brands.
        </p>
    </div>

    <!-- Mission & Vision -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12 animate-slide-up">
        <div class="card card-body bg-gradient-to-br from-primary-50 to-primary-100 dark:from-primary-900/20 dark:to-primary-800/20 border-primary-200 dark:border-primary-800">
            <div class="w-14 h-14 bg-gradient-to-br from-primary-600 to-primary-700 rounded-2xl flex items-center justify-center mb-5 shadow-lg">
                <span class="material-icons text-white text-2xl">flag</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Our Mission</h3>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                To make premium supplements accessible to everyone, helping people achieve their health and fitness goals with quality products at fair prices.
            </p>
        </div>

        <div class="card card-body bg-gradient-to-br from-primary-50 to-primary-100 dark:from-primary-900/20 dark:to-primary-800/20 border-primary-200 dark:border-primary-800">
            <div class="w-14 h-14 bg-gradient-to-br from-primary-600 to-primary-700 rounded-2xl flex items-center justify-center mb-5 shadow-lg">
                <span class="material-icons text-white text-2xl">visibility</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Our Vision</h3>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                To become the most trusted supplement store globally, known for quality, transparency, and exceptional customer satisfaction.
            </p>
        </div>
    </div>

    <!-- Why Choose Us -->
    <div class="card card-body animate-slide-up">
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-3">
            <span class="material-icons text-primary-600 dark:text-primary-400 text-3xl">star</span>
            Why Choose Us?
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-base">
                <div class="w-10 h-10 bg-primary-100 dark:bg-primary-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
                    <span class="material-icons text-primary-600 dark:text-primary-400">check_circle</span>
                </div>
                <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white mb-1">Premium Quality</h4>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Products from trusted brands only</p>
                </div>
            </div>

            <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-base">
                <div class="w-10 h-10 bg-primary-100 dark:bg-primary-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
                    <span class="material-icons text-primary-600 dark:text-primary-400">check_circle</span>
                </div>
                <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white mb-1">Competitive Pricing</h4>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Best prices with regular discounts</p>
                </div>
            </div>

            <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-base">
                <div class="w-10 h-10 bg-primary-100 dark:bg-primary-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
                    <span class="material-icons text-primary-600 dark:text-primary-400">check_circle</span>
                </div>
                <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white mb-1">Fast Shipping</h4>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Reliable delivery worldwide</p>
                </div>
            </div>

            <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-base">
                <div class="w-10 h-10 bg-primary-100 dark:bg-primary-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
                    <span class="material-icons text-primary-600 dark:text-primary-400">check_circle</span>
                </div>
                <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white mb-1">Expert Support</h4>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Knowledgeable team ready to help</p>
                </div>
            </div>

            <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-base">
                <div class="w-10 h-10 bg-primary-100 dark:bg-primary-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
                    <span class="material-icons text-primary-600 dark:text-primary-400">check_circle</span>
                </div>
                <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white mb-1">Secure Shopping</h4>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Safe and encrypted transactions</p>
                </div>
            </div>

            <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-base">
                <div class="w-10 h-10 bg-primary-100 dark:bg-primary-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
                    <span class="material-icons text-primary-600 dark:text-primary-400">check_circle</span>
                </div>
                <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white mb-1">Easy Returns</h4>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Hassle-free return policy</p>
                </div>
            </div>
        </div>
    </div>

    <!-- CTA Section -->
    <div class="mt-12 text-center card card-body bg-gradient-to-br from-primary-600 to-primary-800 text-white animate-slide-up">
        <h3 class="text-2xl font-bold mb-3">Ready to Start Your Journey?</h3>
        <p class="text-primary-100 mb-6 max-w-2xl mx-auto">
            Join thousands of satisfied customers who trust us for their supplement needs.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
            <a href="/Shop" class="btn btn-lg bg-white text-primary-700 hover:bg-primary-50">
                <span class="material-icons">shopping_bag</span>
                Shop Now
            </a>
            <a href="/Home/Contact" class="btn btn-lg bg-white/10 backdrop-blur-sm text-white hover:bg-white/20 border-2 border-white/30">
                <span class="material-icons">contact_support</span>
                Contact Us
            </a>
        </div>
    </div>
</div>
