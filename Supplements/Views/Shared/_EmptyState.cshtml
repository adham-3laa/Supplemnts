@{
    var icon = ViewData["EmptyIcon"] ?? "inventory_2";
    var title = ViewData["EmptyTitle"] ?? "Nothing here yet";
    var message = ViewData["EmptyMessage"] ?? "There are no items to display.";
    var actionText = ViewData["EmptyActionText"];
    var actionUrl = ViewData["EmptyActionUrl"];
}
<div class="flex flex-col items-center justify-center py-20 px-4 text-center animate-fade-in">
    <div class="w-24 h-24 bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-700 rounded-2xl flex items-center justify-center mb-8 shadow-inner">
        <span class="material-icons text-5xl text-gray-400 dark:text-gray-500">@icon</span>
    </div>
    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">@title</h3>
    <p class="text-sm text-gray-500 dark:text-gray-400 max-w-sm mb-8 leading-relaxed">@message</p>
    @if (!string.IsNullOrEmpty(actionText as string) && !string.IsNullOrEmpty(actionUrl as string))
    {
        <a href="@actionUrl" class="btn btn-primary">
            <span class="material-icons text-lg">add</span> @actionText
        </a>
    }
</div>
