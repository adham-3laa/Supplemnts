@{
    var modalId = ViewData["ModalId"] ?? "confirmModal";
    var modalTitle = ViewData["ModalTitle"] ?? "Confirm Action";
    var modalMessage = ViewData["ModalMessage"] ?? "Are you sure?";
    var confirmText = ViewData["ConfirmText"] ?? "Confirm";
    var cancelText = ViewData["CancelText"] ?? "Cancel";
    var confirmClass = ViewData["ConfirmClass"] ?? "bg-red-600 hover:bg-red-700";
    var formAction = ViewData["FormAction"] ?? "";
}

<div id="@modalId" class="fixed inset-0 z-[60] hidden">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity" onclick="closeModal('@modalId')"></div>

    <!-- Modal -->
    <div class="fixed inset-0 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-800 max-w-md w-full p-8 relative animate-scale-in">
            <!-- Close Button -->
            <button onclick="closeModal('@modalId')" class="absolute top-4 right-4 w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-base">
                <span class="material-icons text-lg">close</span>
            </button>

            <div class="text-center">
                <div class="mx-auto w-16 h-16 bg-red-100 dark:bg-red-900/30 rounded-2xl flex items-center justify-center mb-5">
                    <span class="material-icons text-red-600 dark:text-red-400 text-3xl">warning</span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">@modalTitle</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">@modalMessage</p>
            </div>

            <div class="flex gap-3">
                <button type="button" onclick="closeModal('@modalId')"
                        class="flex-1 btn btn-secondary">
                    @cancelText
                </button>
                @if (!string.IsNullOrEmpty(formAction as string))
                {
                    <form method="post" action="@formAction" class="flex-1">
                        <button type="submit" class="w-full px-4 py-2.5 text-sm font-medium text-white rounded-xl transition-base @confirmClass">
                            @confirmText
                        </button>
                    </form>
                }
                else
                {
                    <button type="button" onclick="confirmAction('@modalId')"
                            class="flex-1 px-4 py-2.5 text-sm font-medium text-white rounded-xl transition-base @confirmClass">
                        @confirmText
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id)?.classList.remove('hidden'); }
    function closeModal(id) { document.getElementById(id)?.classList.add('hidden'); }
    function confirmAction(id) { closeModal(id); }
</script>
