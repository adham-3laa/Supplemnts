<!DOCTYPE html>
<html lang="en" class="">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-50 dark:bg-gray-950 antialiased">

    <partial name="_AdminNavbar" />
    <partial name="_Sidebar" />
    <div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-20 hidden lg:hidden"></div>

    <div class="lg:pl-64">
        <main class="min-h-screen p-4 sm:p-6 lg:p-8">
            <partial name="_Breadcrumb" />
            @RenderBody()
        </main>
    </div>

    <div id="toastContainer" class="fixed top-4 right-4 z-[100] flex flex-col gap-3 max-w-sm w-full"></div>

    <script src="~/js/dark-mode.js" asp-append-version="true"></script>
    <script src="~/js/toast.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Success"] != null)
    {
        <script>showToast('@TempData["Success"]', 'success');</script>
    }
    @if (TempData["Error"] != null)
    {
        <script>showToast('@TempData["Error"]', 'error');</script>
    }
</body>
</html>
