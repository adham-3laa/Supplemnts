<!DOCTYPE html>
<html lang="en" class="">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Supplements Store</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100 antialiased">

    <partial name="_Navbar" />

    <main class="min-h-screen">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
            @RenderBody()
        </div>
    </main>

    <partial name="_Footer" />

    <div id="toastContainer" class="fixed top-4 right-4 z-[100] flex flex-col gap-3 max-w-sm w-full"></div>

    <script src="~/js/dark-mode.js" asp-append-version="true"></script>
    <script src="~/js/toast.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Success"] != null)
    {
        <script>showToast('@TempData["Success"]', 'success');</script>
    }
    @if (TempData["Error"] != null)
    {
        <script>showToast('@TempData["Error"]', 'error');</script>
    }
</body>
</html>
