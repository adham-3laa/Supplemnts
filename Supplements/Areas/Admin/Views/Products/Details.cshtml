@model Supplements.Core.Entities.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="max-w-4xl">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.Name</h1>
        <div class="flex items-center gap-2">
            <a href="/Admin/Products/Edit/@Model.Id" class="btn btn-primary btn-sm">
                <span class="material-icons text-lg">edit</span> Edit
            </a>
            <form method="post" action="/Admin/Products/Delete/@Model.Id" onsubmit="return confirmDelete()" class="inline">
                <button type="submit" class="btn btn-danger btn-sm">
                    <span class="material-icons text-lg">delete</span> Delete
                </button>
            </form>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-6">
            <div class="card">
                <div class="card-body space-y-4">
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Description</h4>
                        <p class="mt-1 text-gray-900 dark:text-white">@(Model.Description ?? "No description")</p>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Price</h4>
                            <p class="mt-1 text-2xl font-bold text-gray-900 dark:text-white">$@Model.Price.ToString("N2")</p>
                        </div>
                        <div>
                            <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Discount</h4>
                            <p class="mt-1 text-lg font-semibold text-green-600 dark:text-green-400">@Model.DiscountPercentage%</p>
                        </div>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Stock Quantity</h4>
                        <p class="mt-1 text-lg font-semibold @(Model.StockQuantity <= 5 ? "text-red-600 dark:text-red-400" : "text-gray-900 dark:text-white")">@Model.StockQuantity</p>
                    </div>
                </div>
            </div>

            @if (Model.Variants.Any())
            {
                <div class="card">
                    <div class="card-body">
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Variants</h4>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                                        <th class="text-left px-3 py-2 font-semibold">Flavor</th>
                                        <th class="text-left px-3 py-2 font-semibold">Size</th>
                                        <th class="text-right px-3 py-2 font-semibold">Extra</th>
                                        <th class="text-right px-3 py-2 font-semibold">Stock</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                                    @foreach (var variant in Model.Variants)
                                    {
                                        <tr>
                                            <td class="px-3 py-2 text-gray-900 dark:text-white">@variant.Flavor</td>
                                            <td class="px-3 py-2 text-gray-600 dark:text-gray-400">@variant.Size</td>
                                            <td class="px-3 py-2 text-right text-gray-900 dark:text-white">@(variant.AdditionalPrice > 0 ? "$" + variant.AdditionalPrice.ToString("N2") : "-")</td>
                                            <td class="px-3 py-2 text-right font-medium @(variant.StockQuantity <= 5 ? "text-red-600" : "text-gray-900 dark:text-white")">@variant.StockQuantity</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="space-y-6">
            @if (!string.IsNullOrEmpty(Model.MainImageUrl))
            {
                <div class="card overflow-hidden">
                    <img src="@Model.MainImageUrl" alt="@Model.Name" class="w-full aspect-square object-cover" />
                </div>
            }

            <div class="card">
                <div class="card-body space-y-3">
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Category</h4>
                        <p class="mt-1 text-gray-900 dark:text-white font-medium">@Model.Category?.Name</p>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Brand</h4>
                        <p class="mt-1 text-gray-900 dark:text-white font-medium">@Model.Brand?.Name</p>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Seller</h4>
                        <p class="mt-1 text-gray-900 dark:text-white font-medium">@Model.Seller?.FullName</p>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Created</h4>
                        <p class="mt-1 text-gray-900 dark:text-white">@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</h4>
                        <span class="badge @(Model.IsActive ? "badge-success" : "badge-danger") mt-1">@(Model.IsActive ? "Active" : "Inactive")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
