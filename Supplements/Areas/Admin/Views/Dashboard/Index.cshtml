@model Supplements.ViewModels.Admin.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-8">
    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        <div class="stat-card">
            <span class="material-icons text-3xl text-primary-600 dark:text-primary-400">inventory_2</span>
            <div class="stat-value">@Model.TotalProducts</div>
            <div class="stat-label">Products</div>
        </div>
        <div class="stat-card">
            <span class="material-icons text-3xl text-blue-600 dark:text-blue-400">receipt_long</span>
            <div class="stat-value">@Model.TotalOrders</div>
            <div class="stat-label">Orders</div>
        </div>
        <div class="stat-card">
            <span class="material-icons text-3xl text-green-600 dark:text-green-400">group</span>
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-label">Users</div>
        </div>
        <div class="stat-card">
            <span class="material-icons text-3xl text-purple-600 dark:text-purple-400">category</span>
            <div class="stat-value">@Model.TotalCategories</div>
            <div class="stat-label">Categories</div>
        </div>
        <div class="stat-card">
            <span class="material-icons text-3xl text-orange-600 dark:text-orange-400">branding_watermark</span>
            <div class="stat-value">@Model.TotalBrands</div>
            <div class="stat-label">Brands</div>
        </div>
        <div class="stat-card">
            <span class="material-icons text-3xl text-red-600 dark:text-red-400">inventory</span>
            <div class="stat-value">@Model.LowStockProducts</div>
            <div class="stat-label">Low Stock</div>
        </div>
    </div>

    <!-- Revenue Card -->
    <div class="card">
        <div class="card-body">
            <div class="flex items-center justify-between">
                <div>
                    <p class="stat-label">Total Revenue</p>
                    <p class="text-4xl font-bold text-gray-900 dark:text-white">$@Model.TotalRevenue.ToString("N2")</p>
                </div>
                <div class="w-16 h-16 bg-gradient-to-br from-green-100 to-green-200 dark:from-green-900/30 dark:to-green-800/30 rounded-2xl flex items-center justify-center">
                    <span class="material-icons text-3xl text-green-600 dark:text-green-400">trending_up</span>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Recent Orders -->
        <div class="card">
            <div class="card-body">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">Recent Orders</h3>
                    <a href="/Admin/Orders" class="text-sm font-medium text-primary-600 dark:text-primary-400 hover:underline">View All</a>
                </div>
                @if (Model.RecentOrders.Any())
                {
                    <div class="space-y-4">
                        @foreach (var order in Model.RecentOrders)
                        {
                            <div class="flex items-center justify-between py-3 border-b border-gray-100 dark:border-gray-800 last:border-0">
                                <div>
                                    <a href="/Admin/Orders/Details/@order.Id" class="text-sm font-semibold text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400">@order.CustomerName</a>
                                    <p class="text-xs text-gray-500 dark:text-gray-400">@order.OrderDate.ToString("MMM dd, yyyy")</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm font-semibold text-gray-900 dark:text-white">$@order.TotalPrice.ToString("N2")</p>
                                    <span class="badge @(order.Status switch { "Delivered" => "badge-success", "Cancelled" => "badge-danger", "Pending" => "badge-warning", "Processing" => "badge-info", "Shipped" => "badge-primary", _ => "badge-info" })">@order.Status</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-gray-500 dark:text-gray-400">No orders yet</p>
                }
            </div>
        </div>

        <!-- Top Products -->
        <div class="card">
            <div class="card-body">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-6">Top Selling Products</h3>
                @if (Model.TopProducts.Any())
                {
                    <div class="space-y-4">
                        @foreach (var product in Model.TopProducts.Select((item, index) => new { item, index }))
                        {
                            <div class="flex items-center gap-4 py-3 border-b border-gray-100 dark:border-gray-800 last:border-0">
                                <span class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-sm font-bold text-gray-600 dark:text-gray-400">@(product.index + 1)</span>
                                <div class="flex-1">
                                    <p class="text-sm font-semibold text-gray-900 dark:text-white">@product.item.Name</p>
                                    <p class="text-xs text-gray-500 dark:text-gray-400">@product.item.TotalSold sold</p>
                                </div>
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">$@product.item.Revenue.ToString("N2")</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-gray-500 dark:text-gray-400">No sales data yet</p>
                }
            </div>
        </div>
    </div>
</div>
