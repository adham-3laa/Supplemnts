@model List<Supplements.ViewModels.Admin.UserManageViewModel>
@{
    ViewData["Title"] = "Users";
}

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Users</h1>
    </div>

    <form method="get" class="flex gap-3">
        <input type="text" name="search" value="@ViewBag.Search" placeholder="Search users..." class="input max-w-sm" />
        <button type="submit" class="btn btn-primary">Search</button>
    </form>

    <div class="card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                        <th class="text-left px-4 py-3 font-semibold">User</th>
                        <th class="text-left px-4 py-3 font-semibold">Email</th>
                        <th class="text-left px-4 py-3 font-semibold">Roles</th>
                        <th class="text-center px-4 py-3 font-semibold">Status</th>
                        <th class="text-left px-4 py-3 font-semibold">Joined</th>
                        <th class="text-right px-4 py-3 font-semibold">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                    @foreach (var user in Model)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-primary-100 to-primary-200 dark:from-primary-900/30 dark:to-primary-800/30 flex items-center justify-center">
                                        <span class="material-icons text-primary-600 dark:text-primary-400 text-lg">person</span>
                                    </div>
                                    <span class="font-medium text-gray-900 dark:text-white">@user.FullName</span>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-gray-600 dark:text-gray-400">@user.Email</td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge @(role == "Admin" ? "badge-danger" : role == "Seller" ? "badge-primary" : "badge-info")">@role</span>
                                    }
                                </div>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="badge @(user.IsActive ? "badge-success" : "badge-danger")">@(user.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td class="px-4 py-3 text-gray-600 dark:text-gray-400">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="px-4 py-3 text-right">
                                <a href="/Admin/Users/Details/@user.Id" class="btn btn-sm btn-secondary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav class="flex items-center justify-center gap-2 mt-8">
            @if (ViewBag.Page > 1)
            {
                <a href="?page=@(ViewBag.Page - 1)&search=@ViewBag.Search" class="btn btn-secondary btn-sm">Previous</a>
            }
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a href="?page=@i&search=@ViewBag.Search" class="btn btn-sm @(i == ViewBag.Page ? "btn-primary" : "btn-secondary")">@i</a>
            }
            @if (ViewBag.Page < ViewBag.TotalPages)
            {
                <a href="?page=@(ViewBag.Page + 1)&search=@ViewBag.Search" class="btn btn-secondary btn-sm">Next</a>
            }
        </nav>
    }
</div>
