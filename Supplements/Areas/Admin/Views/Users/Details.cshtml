@model Supplements.Core.Entities.User
@{
    ViewData["Title"] = Model.FullName;
    var userRoles = ViewBag.UserRoles as IList<string> ?? new List<string>();
    var allRoles = ViewBag.AllRoles as List<string> ?? new List<string>();
}

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-100 to-primary-200 dark:from-primary-900/30 dark:to-primary-800/30 flex items-center justify-center">
                <span class="material-icons text-3xl text-primary-600 dark:text-primary-400">person</span>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.FullName</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400">@Model.Email</p>
            </div>
        </div>
        <form method="post" action="/Admin/Users/ToggleActive/@Model.Id">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn @(Model.IsActive ? "btn-danger" : "btn-primary")">
                <span class="material-icons text-lg">@(Model.IsActive ? "block" : "check_circle")</span>
                @(Model.IsActive ? "Deactivate" : "Activate")
            </button>
        </form>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-6">
            <div class="card">
                <div class="card-body">
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Orders</h3>
                    @if (Model.Orders.Any())
                    {
                        <div class="space-y-3">
                            @foreach (var order in Model.Orders.Take(10))
                            {
                                <div class="flex items-center justify-between py-3 border-b border-gray-100 dark:border-gray-800 last:border-0">
                                    <div>
                                        <a href="/Admin/Orders/Details/@order.Id" class="text-sm font-medium text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400 font-mono">#@order.Id.ToString("N")</a>
                                        <p class="text-xs text-gray-500 dark:text-gray-400">@order.OrderDate.ToString("MMM dd, yyyy")</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-sm font-semibold text-gray-900 dark:text-white">$@order.TotalPrice.ToString("N2")</p>
                                        <span class="badge @(order.Status switch { "Delivered" => "badge-success", "Cancelled" => "badge-danger", "Pending" => "badge-warning", "Processing" => "badge-info", "Shipped" => "badge-primary", _ => "badge-info" })">@order.Status</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-sm text-gray-500 dark:text-gray-400">No orders yet</p>
                    }
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="card">
                <div class="card-body space-y-3">
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Phone</h4>
                        <p class="mt-1 text-gray-900 dark:text-white">@(Model.PhoneNumber ?? "—")</p>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</h4>
                        <span class="badge @(Model.IsActive ? "badge-success" : "badge-danger") mt-1">@(Model.IsActive ? "Active" : "Inactive")</span>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Joined</h4>
                        <p class="mt-1 text-gray-900 dark:text-white">@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Roles</h4>
                    <div class="space-y-2 mb-4">
                        @foreach (var role in userRoles)
                        {
                            <div class="flex items-center justify-between py-2 px-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
                                <span class="text-sm font-medium text-gray-900 dark:text-white">@role</span>
                                <form method="post" action="/Admin/Users/RemoveRole/@Model.Id" onsubmit="return confirm('Remove role @role from this user?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="role" value="@role" />
                                    <button type="submit" class="text-red-600 hover:text-red-700 dark:text-red-400 text-sm">Remove</button>
                                </form>
                            </div>
                        }
                    </div>

                    @{
                        var availableRoles = allRoles.Except(userRoles).ToList();
                    }
                    @if (availableRoles.Any())
                    {
                        <form method="post" action="/Admin/Users/AddRole/@Model.Id" class="flex gap-2">
                            @Html.AntiForgeryToken()
                            <select name="role" class="input text-sm flex-1">
                                @foreach (var role in availableRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm">Add</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
